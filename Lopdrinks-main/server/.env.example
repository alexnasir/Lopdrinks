# -----------------------------------------------------------------------
# Environment variable template.
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# -----------------------------------------------------------------------

# Application environment: development | testing | production
APP_ENV=development

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret

# JWT signing key (generate separately for rotation independence)
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret

# Database connection string
# SQLite (local dev): sqlite:///coffee.db
# PostgreSQL (production): postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///coffee.db

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Port (optional, defaults to 5000)
PORT=5000
